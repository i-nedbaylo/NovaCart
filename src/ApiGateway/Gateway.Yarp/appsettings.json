{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Debug"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "products-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/api/v1/products/{**catch-all}"
        }
      },
      "categories-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/api/v1/categories/{**catch-all}"
        }
      },
      "orders-route": {
        "ClusterId": "ordering-cluster",
        "Match": {
          "Path": "/api/v1/orders/{**catch-all}"
        }
      },
      "auth-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        }
      },
      "baskets-route": {
        "ClusterId": "basket-cluster",
        "Match": {
          "Path": "/api/v1/baskets/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "catalog-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https+http://catalog-api"
          }
        }
      },
      "ordering-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https+http://ordering-api"
          }
        }
      },
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https+http://identity-api"
          }
        }
      },
      "basket-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https+http://basket-api"
          }
        }
      }
    }
  }
}
