@page "/login"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using Microsoft.AspNetCore.Http
@using NovaCart.Web.Services
@using NovaCart.Web.Services.Models
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>NovaCart — Login</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small">
    <MudPaper Elevation="2" Class="pa-8 mt-8">
        <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true">Sign In</MudText>

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@_errorMessage</MudAlert>
        }

        <EditForm Model="Input" method="post" OnValidSubmit="LoginUser" FormName="login">
            <DataAnnotationsValidator />

            <div class="mb-4">
                <label for="email"><MudText Typo="Typo.subtitle2">Email</MudText></label>
                <InputText id="email" @bind-Value="Input.Email" type="email" autocomplete="username"
                           style="width:100%;padding:10px;margin-top:4px;border:1px solid #ccc;border-radius:4px;" />
                <ValidationMessage For="() => Input.Email" />
            </div>

            <div class="mb-4">
                <label for="password"><MudText Typo="Typo.subtitle2">Password</MudText></label>
                <InputText id="password" @bind-Value="Input.Password" type="password" autocomplete="current-password"
                           style="width:100%;padding:10px;margin-top:4px;border:1px solid #ccc;border-radius:4px;" />
                <ValidationMessage For="() => Input.Password" />
            </div>

            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
                       FullWidth="true" Class="mt-2">
                Sign In
            </MudButton>
        </EditForm>

        <MudText Align="Align.Center" Class="mt-4">
            Don't have an account?
            <MudLink Href="/register">Sign Up</MudLink>
        </MudText>
    </MudPaper>
</MudContainer>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private LoginInputModel Input { get; set; } = new();

    private string? _errorMessage;

    private async Task LoginUser()
    {
        var token = await AuthService.LoginAsync(new LoginModel(Input.Email, Input.Password));
        if (token is null)
        {
            _errorMessage = "Invalid email or password.";
            return;
        }

        var principal = BffAuth.BuildPrincipal(token);
        await HttpContext.SignInAsync(
            CookieAuthenticationDefaults.AuthenticationScheme,
            principal,
            new AuthenticationProperties { IsPersistent = true });

        Navigation.NavigateTo("/", forceLoad: true);
    }

    public sealed class LoginInputModel
    {
        [Required, EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required]
        public string Password { get; set; } = string.Empty;
    }
}
