@page "/register"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using Microsoft.AspNetCore.Http
@using NovaCart.Web.Services
@using NovaCart.Web.Services.Models
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>NovaCart — Register</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small">
    <MudPaper Elevation="2" Class="pa-8 mt-8">
        <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true">Create Account</MudText>

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@_errorMessage</MudAlert>
        }

        <EditForm Model="Input" method="post" OnValidSubmit="RegisterUser" FormName="register">
            <DataAnnotationsValidator />

            <div class="mb-4">
                <label for="firstName"><MudText Typo="Typo.subtitle2">First Name</MudText></label>
                <InputText id="firstName" @bind-Value="Input.FirstName"
                           style="width:100%;padding:10px;margin-top:4px;border:1px solid #ccc;border-radius:4px;" />
                <ValidationMessage For="() => Input.FirstName" />
            </div>

            <div class="mb-4">
                <label for="lastName"><MudText Typo="Typo.subtitle2">Last Name</MudText></label>
                <InputText id="lastName" @bind-Value="Input.LastName"
                           style="width:100%;padding:10px;margin-top:4px;border:1px solid #ccc;border-radius:4px;" />
                <ValidationMessage For="() => Input.LastName" />
            </div>

            <div class="mb-4">
                <label for="email"><MudText Typo="Typo.subtitle2">Email</MudText></label>
                <InputText id="email" @bind-Value="Input.Email" type="email" autocomplete="username"
                           style="width:100%;padding:10px;margin-top:4px;border:1px solid #ccc;border-radius:4px;" />
                <ValidationMessage For="() => Input.Email" />
            </div>

            <div class="mb-4">
                <label for="password"><MudText Typo="Typo.subtitle2">Password</MudText></label>
                <InputText id="password" @bind-Value="Input.Password" type="password" autocomplete="new-password"
                           style="width:100%;padding:10px;margin-top:4px;border:1px solid #ccc;border-radius:4px;" />
                <ValidationMessage For="() => Input.Password" />
            </div>

            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
                       FullWidth="true" Class="mt-2">
                Create Account
            </MudButton>
        </EditForm>

        <MudText Align="Align.Center" Class="mt-4">
            Already have an account?
            <MudLink Href="/login">Sign In</MudLink>
        </MudText>
    </MudPaper>
</MudContainer>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private RegisterInputModel Input { get; set; } = new();

    private string? _errorMessage;

    private async Task RegisterUser()
    {
        var response = await AuthService.RegisterAsync(
            new RegisterModel(Input.Email, Input.Password, Input.FirstName, Input.LastName));

        if (!response.IsSuccessStatusCode)
        {
            _errorMessage = "Registration failed. The email may already be in use, " +
                            "or the password does not meet the requirements (8+ chars, upper, lower, digit).";
            return;
        }

        // Auto sign-in after a successful registration.
        var token = await AuthService.LoginAsync(new LoginModel(Input.Email, Input.Password));
        if (token is not null)
        {
            var principal = BffAuth.BuildPrincipal(token);
            await HttpContext.SignInAsync(
                CookieAuthenticationDefaults.AuthenticationScheme,
                principal,
                new AuthenticationProperties { IsPersistent = true });

            Navigation.NavigateTo("/", forceLoad: true);
            return;
        }

        Navigation.NavigateTo("/login");
    }

    public sealed class RegisterInputModel
    {
        [Required]
        public string FirstName { get; set; } = string.Empty;

        [Required]
        public string LastName { get; set; } = string.Empty;

        [Required, EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required, MinLength(8, ErrorMessage = "Password must be at least 8 characters.")]
        public string Password { get; set; } = string.Empty;
    }
}
